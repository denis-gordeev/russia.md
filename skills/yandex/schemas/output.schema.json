{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Yandex Skill Output",
  "type": "object",
  "required": ["task_type", "input", "resolved_location", "alternatives", "confidence", "business_warning"],
  "properties": {
    "task_type": { "type": "string", "enum": ["geocode", "route", "serviceability", "planning"] },
    "input": { "type": "string" },
    "resolved_location": { "type": ["object", "null"] },
    "alternatives": { "type": "array", "items": {} },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "business_warning": { "type": "string" }
  },
  "additionalProperties": true
}
