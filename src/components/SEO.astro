---
interface Props {
  title: string;
  description?: string;
  image?: string;
  url?: string;
  lang?: 'zh-TW' | 'en';
  type?: 'website' | 'article';
  datePublished?: string;
  dateModified?: string;
  content?: string;
  tags?: string[];
  category?: string;
}

const {
  title,
  description = 'Open-source, AI-friendly knowledge base about Russia.',
  image = '/favicon.png',
  url = Astro.url.href,
  lang = 'zh-TW',
  type = 'website',
  datePublished,
  dateModified,
  content,
  tags,
  category
} = Astro.props;

const fullTitle = `${title} | Russia.md`;
const siteUrl = 'https://russia-md.ru';
const fullImageUrl = new URL(image, siteUrl).href;

// Generate AI-friendly summary from description or content
const aiSummary = description || (content ? content.substring(0, 200).replace(/[\n\r]/g, ' ').replace(/[#*]/g, '').trim() + '...' : '');

// Generate JSON-LD structured data
const generateJSONLD = () => {
  if (type === 'article' && datePublished) {
    return {
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": title,
      "description": description,
      "author": {
        "@type": "Organization",
        "name": "Russia.md"
      },
      "publisher": {
        "@type": "Organization", 
        "name": "Russia.md",
        "url": siteUrl,
        "logo": {
          "@type": "ImageObject",
          "url": `${siteUrl}/favicon.png`
        }
      },
      "datePublished": datePublished,
      "dateModified": dateModified || datePublished,
      "inLanguage": lang,
      "url": url,
      "image": fullImageUrl,
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": url
      }
    };
  } else {
    return {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Russia.md",
      "description": "Open-source, AI-friendly knowledge base about Russia",
      "url": siteUrl,
      "inLanguage": lang,
      "publisher": {
        "@type": "Organization",
        "name": "Russia.md",
        "url": siteUrl
      }
    };
  }
};

const jsonLD = generateJSONLD();

// Dynamic keywords
const baseKeywords = 'Russia, Russian history, Russian culture, Russian economy, Russian geography';
const dynamicKeywords = [
  baseKeywords,
  ...(category ? [category] : []),
  ...(tags && tags.length > 0 ? tags : [])
].join(', ');

// BreadcrumbList JSON-LD for article pages
const breadcrumbLD = (type === 'article' && category) ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Russia.md", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": category, "item": `${siteUrl}/${category}` },
    { "@type": "ListItem", "position": 3, "name": title }
  ]
} : null;
---

<!-- Basic Meta Tags -->
<meta name="description" content={description} />
<meta name="keywords" content={dynamicKeywords} />
<meta name="author" content="Russia.md" />
<meta name="generator" content="Russia.md" />

<!-- AI-friendly summary meta tag -->
<meta name="ai-summary" content={aiSummary} />

<!-- Canonical URL -->
<link rel="canonical" href={url} />

<!-- RSS Feed -->
<link rel="alternate" type="application/rss+xml" title="Russia.md RSS Feed" href={`${siteUrl}/feed.xml`} />

<!-- Language Tags -->
<link rel="alternate" hreflang="en" href={siteUrl} />
<link rel="alternate" hreflang="x-default" href={siteUrl} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={url} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={fullImageUrl} />
<meta property="og:image:alt" content={`${title} - Russia.md`} />
<meta property="og:site_name" content="Russia.md" />
<meta property="og:locale" content="en_US" />
{datePublished && <meta property="article:published_time" content={datePublished} />}
{dateModified && <meta property="article:modified_time" content={dateModified} />}
{tags && tags.map((tag: string) => (
  <meta property="article:tag" content={tag} />
))}

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={url} />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={fullImageUrl} />
<meta name="twitter:image:alt" content={`${title} - Russia.md`} />

<!-- Additional SEO -->
<meta name="robots" content="index, follow" />
<meta name="googlebot" content="index, follow" />

<!-- JSON-LD Structured Data -->
<script type="application/ld+json" set:html={JSON.stringify(jsonLD, null, 2)} />
{breadcrumbLD && (
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLD, null, 2)} />
)}
