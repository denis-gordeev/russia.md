---
import Layout from '../layouts/Layout.astro';

const sections = [
  {
    title: 'Government and Public Data',
    items: [
      ['Gosuslugi', 'https://www.gosuslugi.ru/'],
      ['Rosstat', 'https://rosstat.gov.ru/'],
      ['Federal Tax Service', 'https://www.nalog.gov.ru/'],
      ['Central Bank of Russia', 'https://cbr.ru/'],
    ],
  },
  {
    title: 'Mapping and Reference',
    items: [
      ['Yandex Maps API', 'https://yandex.com/maps-api/'],
      ['OpenStreetMap Russia', 'https://www.openstreetmap.org/'],
      ['DaData', 'https://dadata.ru/'],
    ],
  },
  {
    title: 'Platforms and Identity',
    items: [
      ['VK Developers', 'https://dev.vk.com/'],
      ['VK ID', 'https://id.vk.com/about/business'],
    ],
  },
];
---

<Layout
  title="Resources"
  description="Official entry points and practical reference links for expanding the Russia.md fork."
>
  <main class="page">
    <section class="wrap">
      <p class="eyebrow">Resources</p>
      <h1>Official and practical links</h1>
      <p>
        This page is intentionally short. It collects the entry points that are most useful for extending
        the repo with sourced content, data notes, and agent integrations.
      </p>
    </section>

    <section class="wrap list-grid">
      {sections.map((section) => (
        <article class="list-card">
          <h2>{section.title}</h2>
          <ul>
            {section.items.map(([label, url]) => (
              <li><a href={url} target="_blank" rel="noopener noreferrer">{label}</a></li>
            ))}
          </ul>
        </article>
      ))}
    </section>
  </main>
</Layout>

<style>
  .page {
    padding: 4rem 1.5rem;
  }

  .wrap {
    max-width: 960px;
    margin: 0 auto 2rem;
  }

  .list-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.25rem;
  }

  .list-card {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 20px;
    padding: 1.25rem;
  }

  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.78rem;
    color: #64748b;
  }

  p, li {
    line-height: 1.8;
    color: #334155;
  }
</style>
